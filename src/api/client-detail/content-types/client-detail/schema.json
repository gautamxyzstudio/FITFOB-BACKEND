{
  "kind": "collectionType",
  "collectionName": "client_details",
  "info": {
    "singularName": "client-detail",
    "pluralName": "client-details",
    "displayName": "Client-Detail"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "gender": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "phoneNumber": {
      "type": "string"
    },
    "weight": {
      "type": "string"
    },
    "height": {
      "type": "string"
    },
    "longitude": {
      "type": "string"
    },
    "latitude": {
      "type": "string"
    },
    "selfieUpload": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "governmentId": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "approvedAt": {
      "type": "datetime"
    },
    "date_of_birth": {
      "type": "date"
    },
      "clientId": {
      "type": "string",
      "unique": true
    },
    "local_subscriptions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::local-subscription.local-subscription",
      "mappedBy": "client_detail"
    },
    "outdoor_subscriptions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::outdoor-subscription.outdoor-subscription",
      "mappedBy": "client_detail"
    },
    "client_checkins": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::client-checkin.client-checkin",
      "mappedBy": "client_detail"
    }
  }
}
