{
  "kind": "collectionType",
  "collectionName": "club_owners",
  "info": {
    "singularName": "club-owner",
    "pluralName": "club-owners",
    "displayName": "Club-Owner"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "clubId": {
      "type": "string",
      "required": true,
      "unique": true,
      "configurable": false
    },
    "ownerName": {
      "type": "string"
    },
    "phoneNumber": {
      "type": "string"
    },
    "email": {
      "type": "email"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "clubName": {
      "type": "string"
    },
    "openingTime": {
      "type": "time"
    },
    "closingTime": {
      "type": "time"
    },
    "clubPhotos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "weekday": {
      "type": "string"
    },
    "weekend": {
      "type": "string"
    },
    "facilities": {
      "type": "json"
    },
    "services": {
      "type": "json"
    },
    "latitude": {
      "type": "string"
    },
    "longitude": {
      "type": "string"
    },
    "clubAddress": {
      "type": "string"
    },
    "pincode": {
      "type": "string"
    },
    "city": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "club_owner_documents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::club-owner-document.club-owner-document",
      "mappedBy": "club_owner"
    },
    "clubCategory": {
      "type": "enumeration",
      "enum": [
        "Basic",
        "Premium",
        "Luxury"
      ]
    },
    "local_membership_plans": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::local-membership-plan.local-membership-plan",
      "mappedBy": "club_owner"
    },
    "local_subscriptions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::local-subscription.local-subscription",
      "mappedBy": "club_owner"
    },
    "client_checkins": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::client-checkin.client-checkin",
      "mappedBy": "club_owner"
    }
  }
}
