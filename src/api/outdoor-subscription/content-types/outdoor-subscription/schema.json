{
  "kind": "collectionType",
  "collectionName": "outdoor_subscriptions",
  "info": {
    "singularName": "outdoor-subscription",
    "pluralName": "outdoor-subscriptions",
    "displayName": "outdoor-subscription"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "client_detail": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::client-detail.client-detail",
      "inversedBy": "outdoor_subscriptions"
    },
    "outdoor_membership_plan": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::outdoor-membership-plan.outdoor-membership-plan",
      "inversedBy": "outdoor_subscriptions"
    },
    "totalVisitsAllowed": {
      "type": "integer"
    },
    "usedVisits": {
      "type": "integer",
      "default": 0
    },
    "remainingVisits": {
      "type": "integer"
    },
    "subscriptionStatus": {
      "type": "enumeration",
      "enum": [
        "active",
        "cancelled",
        "expired"
      ]
    },
    "client_checkins": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::client-checkin.client-checkin",
      "mappedBy": "outdoor_subscription"
    }
  }
}
